{
  "_version": "1.84.0",
  "sap.app": {
    "id": "project1",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.23.0",
      "toolsId": "01082b95-d84b-44d3-8509-a6f61cdc1417"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/myservice/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "rootView": {
  "viewName": "sap.fe.core.rootView.Fcl",
  "type": "XML",
  "async": true,
  "id": "appRootView"
},"flexibleColumnLayout":{
                "defaultTwoColumnLayoutType":"TwoColumnsMidExpanded",
                "defaultThreeColumnLayoutType":"ThreeColumnsMidExpanded"
            },
    "dependencies": {
      "minUI5Version": "1.147.2",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "project1.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {
        "routerClass":"sap.f.routing.Router",
        "viewType": "XML",
        "async": true
      },
      "routes": [
        {
          "pattern": ":?query:",
          "name": "userList",
          "target": ["userList"]
        },
        {
          "pattern": "user({key},IsActiveEntity={IsActiveEntity}):?query:",
          "name": "userObjectPage",
                    "target": ["userList","userObjectPage"]
        },
        {
          "pattern":  "user({key},IsActiveEntity={IsActiveEntity})/role({key2},IsActiveEntity={IsActiveEntity2}):?query:",
          "name": "roleObjectPage",
          "target": ["userList","userObjectPage","roleObjectPage"]
        }
      ],
      "targets": {
        "userList": {
          "type": "Component",
          "id": "userList",
          "name": "sap.fe.templates.ListReport",
                    "controlAggregation": "beginColumnPages",

          "options": {
            "settings": {
              "initialLoad":"Enabled",
              "contextPath": "/user",
              "variantManagement": "Page",
              "navigation": {
                "user": {
                  "detail": {
                    "route": "userObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              }
            }
          }
        },
        "userObjectPage": {
          "type": "Component",
          "id": "userObjectPage",
          "name": "sap.fe.templates.ObjectPage",
                      "controlAggregation": "midColumnPages",
            "contextPattern": "/user({key},IsActiveEntity={IsActiveEntity})",

          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/user",
              "navigation": {
        "role": {
          "detail": {
            "route": "roleObjectPage"
          }
        }
      }
            }
          }
        },
        "roleObjectPage": {
          "type": "Component",
          "id": "roleObjectPage",
          "name": "sap.fe.templates.ObjectPage",
                      "controlAggregation": "endColumnPages",
            "contextPattern": "/user({key},IsActiveEntity={IsActiveEntity})/role({key2},IsActiveEntity={IsActiveEntity2})",

          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/role"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
