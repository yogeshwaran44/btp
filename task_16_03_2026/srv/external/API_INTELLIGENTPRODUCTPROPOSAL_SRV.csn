{
 "meta": {
  "creator": "cds-dk 9.6.1"
 },
 "$version": "2.0",
 "definitions": {
  "API_INTELLIGENTPRODUCTPROPOSAL_SRV": {
   "kind": "service",
   "@cds.external": true,
   "@m.IsDefaultEntityContainer": "true",
   "@sap.message.scope.supported": "true",
   "@sap.supported.formats": "atom json xlsx"
  },
  "API_INTELLIGENTPRODUCTPROPOSAL_SRV.A_SalesDocumentProposalItem": {
   "kind": "entity",
   "@cds.external": true,
   "@cds.persistence.skip": true,
   "@sap.creatable": "false",
   "@sap.updatable": "false",
   "@sap.deletable": "false",
   "@sap.content.version": "1",
   "@sap.label": "Product Proposal for Sales Order Item",
   "elements": {
    "SalesOrganization": {
     "key": true,
     "type": "cds.String",
     "length": 4,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Sales Organization",
     "notNull": true
    },
    "DistributionChannel": {
     "key": true,
     "type": "cds.String",
     "length": 2,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Distribution Channel",
     "notNull": true
    },
    "OrganizationDivision": {
     "key": true,
     "type": "cds.String",
     "length": 2,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Division",
     "notNull": true
    },
    "SalesGroup": {
     "key": true,
     "type": "cds.String",
     "length": 3,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Sales Group",
     "notNull": true
    },
    "SalesOffice": {
     "key": true,
     "type": "cds.String",
     "length": 4,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Sales Office",
     "notNull": true
    },
    "SoldToParty": {
     "key": true,
     "type": "cds.String",
     "length": 10,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Customer",
     "@sap.quickinfo": "Customer Number",
     "notNull": true
    },
    "SalesDocumentType": {
     "key": true,
     "type": "cds.String",
     "length": 4,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Sales Document Type",
     "notNull": true
    },
    "Product": {
     "type": "cds.String",
     "length": 40,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Material",
     "@sap.quickinfo": "Material Number",
     "@sap.filterable": "false"
    },
    "Batch": {
     "type": "cds.String",
     "length": 10,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Batch",
     "@sap.quickinfo": "Batch Number",
     "@sap.filterable": "false"
    },
    "OrderQuantity": {
     "type": "cds.Decimal",
     "precision": 15,
     "scale": 3,
     "@sap.unit": "OrderQuantityUnit",
     "@sap.label": "IP quantity",
     "@sap.quickinfo": "Item proposal quantity",
     "@sap.filterable": "false"
    },
    "OrderQuantityUnit": {
     "type": "cds.String",
     "length": 3,
     "@sap.label": "Sales Unit",
     "@sap.filterable": "false",
     "@sap.semantics": "unit-of-measure"
    }
   }
  }
 }
}